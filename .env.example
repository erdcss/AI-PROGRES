# Uygulama ortam değişkenleri (örnek)
# Kopyalayın: cp .env.example .env

# --- Shopify (önerilen) ---
SHOPIFY_SHOP_DOMAIN=magaza-adi.myshopify.com
SHOPIFY_CLIENT_ID=
# Dev Dashboard Client Secret (shpsec_...) — API secret (shpss_...) ile karıştırmayın
SHOPIFY_CLIENT_SECRET=

# Opsiyonel manuel token (client_credentials yerine):
# SHOPIFY_ADMIN_ACCESS_TOKEN=shpat_...
# SHOPIFY_ACCESS_TOKEN=shpat_...

# Opsiyonel Shopify API test base URL (npm run shopify:health):
# SHOPIFY_TEST_BASE_URL=http://127.0.0.1:3000

# Legacy alias (önerilmez):
# secret_key=shpsec_...
# SHOPIFY_API_KEY=...
# SHOPIFY_APP_SHARED_SECRET=...
# SHOPIFY_APP_SECRET_NEW=shpat_...  # yanıltıcı isim — SHOPIFY_ADMIN_ACCESS_TOKEN kullanın

# --- Production scraping (önerilen) ---
BROWSER_WORKER_URL=
BROWSER_WORKER_ENDPOINT=
BROWSER_WORKER_TOKEN=change-me
BROWSER_WORKER_TIMEOUT_MS=45000
SCRAPE_PROVIDER_PRIORITY=browser_worker,trendyol_api,direct_html,local_agent

# --- Geçici/geliştirme fallback (production primary değil) ---
INTERNAL_LOCAL_AGENT_ENDPOINT=
INTERNAL_LOCAL_AGENT_TOKEN=
LOCAL_AGENT_TOKEN=change-me
LOCAL_AGENT_PORT=3847

# --- Telegram bildirimleri ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Ürün takip worker ---
PRODUCT_TRACKING_ENABLED=false
PRODUCT_TRACKING_INTERVAL_MINUTES=30

# --- Uygulama ---
# DATABASE_URL=
# ADMIN_SECRET=

# --- Trendyol → Shopify export ---
SHOPIFY_DEFAULT_IN_STOCK_QTY=10
SHOPIFY_LIMITED_STOCK_QTY=3
TRENDYOL_EXPORT_OUT_OF_STOCK_VARIANTS=false

# Not: Tokenlar loglanmamalıdır.
