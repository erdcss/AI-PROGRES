# Uygulama ortam değişkenleri (örnek)
# Kopyalayın: cp .env.example .env

# --- Local Scrape Agent (Railway → Windows PC) ---
# Railway/Cloud backend'in Windows PC'de çalışan Local Agent'a ulaşması için gerekir.
# Cloudflare Tunnel her yeniden başlatıldığında trycloudflare adresi değişebilir.
INTERNAL_LOCAL_AGENT_ENDPOINT=https://your-current-tunnel.trycloudflare.com

# Railway ile local-agent terminalinde aynı olmalı. Gizli tutulmalı.
INTERNAL_LOCAL_AGENT_TOKEN=change-me

# Yerel agent (Windows'ta npm run agent)
LOCAL_AGENT_TOKEN=change-me
LOCAL_AGENT_PORT=3847

# --- Diğer internal kaynak erişimi (isteğe bağlı) ---
# INTERNAL_PROXY_URL=
# INTERNAL_SCRAPING_API_ENDPOINT=
# INTERNAL_SCRAPING_API_KEY=

# --- Uygulama ---
# DATABASE_URL=
# ADMIN_SECRET=
