# Uygulama ortam değişkenleri (örnek)
# Kopyalayın: cp .env.example .env

# --- Production: Cloud Browser Worker (önerilen) ---
# Bağımsız Playwright servisi — Railway'de ayrı servis olarak deploy edilir.
BROWSER_WORKER_ENDPOINT=https://your-browser-worker-domain.com
BROWSER_WORKER_TOKEN=change-me

# --- Geçici/geliştirme fallback (production önerilmez) ---
# trycloudflare adresi her tunnel yeniden başlatıldığında değişir.
INTERNAL_LOCAL_AGENT_ENDPOINT=
INTERNAL_LOCAL_AGENT_TOKEN=
LOCAL_AGENT_TOKEN=change-me
LOCAL_AGENT_PORT=3847

# --- Telegram bildirimleri (ürün takip) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Ürün takip worker ---
PRODUCT_TRACKING_ENABLED=false
PRODUCT_TRACKING_INTERVAL_MINUTES=30

# --- Diğer internal kaynak erişimi (isteğe bağlı) ---
# INTERNAL_PROXY_URL=
# INTERNAL_SCRAPING_API_ENDPOINT=
# INTERNAL_SCRAPING_API_KEY=

# --- Uygulama ---
# DATABASE_URL=
# ADMIN_SECRET=

# Not: Tokenlar loglanmamalıdır. Production'da BROWSER_WORKER_* kullanın.
