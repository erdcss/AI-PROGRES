run = "npm run dev"
modules = ["postgresql-16"]

[nix]
channel = "stable-24_05"
packages = [
  "nodejs_20",
  "python3_11",
  "python3Packages.pip",
  "chromium",
  "glibcLocales",
]

[deployment]
deploymentTarget = "autoscale"
build = "npm run build"
run = "npm start"

[[ports]]
localPort = 3000
externalPort = 80

[[ports]]
localPort = 5000
externalPort = 5000

[[ports]]
localPort = 43091
externalPort = 6000

[[ports]]
localPort = 45075
externalPort = 3002
