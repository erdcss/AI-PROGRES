run = "npm run dev"
modules = ["nodejs-20", "postgresql-16"]

[nix]
channel = "stable-24_05"
packages = [
  "nodejs_20",
  "python3_11",
  "python3Packages.pip",
  "chromium",
  "glibcLocales",
]

[deployment]
deploymentTarget = "autoscale"
build = "npm run build"
run = "npm start"

[[ports]]
localPort = 3000
externalPort = 80

[[ports]]
localPort = 5000
externalPort = 5000

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"
